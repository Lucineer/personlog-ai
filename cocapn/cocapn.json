{
  "name": "PersonalAgent",
  "version": "1.0.0",
  "provider": "deepseek",
  "model": "deepseek-chat",
  "maxMemories": 1000,
  "guestLimit": 5,
  "channels": {
    "web": true,
    "telegram": false,
    "discord": false,
    "whatsapp": false,
    "email": false
  },
  "a2a": {
    "enabled": true,
    "maxPeers": 50,
    "discoveryTimeout": 5000
  },
  "analytics": {
    "enabled": true,
    "retentionDays": 90
  }
}
